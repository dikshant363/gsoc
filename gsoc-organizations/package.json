  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "lint": "prettier -c \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "redoc": "redoc-cli serve api/openapi.yml",
    "prepare": "node -e \"process.exit(process.env.CI || process.env.VERCEL ? 0 : 1)\" || husky install",
    "api:start": "node api/server.js",
    "ingest:all": "node scripts/ingest/pipeline.js",
    "ingest:ingest": "node scripts/ingest/pipeline.js --ingest-only",
    "ingest:normalize": "node scripts/ingest/pipeline.js --normalize-only",
    "ingest:build": "node scripts/ingest/pipeline.js --build-only",
    "qdrant:start": "docker-compose up -d",
    "qdrant:stop": "docker-compose down",
    "qdrant:logs": "docker-compose logs -f qdrant",
    "index:build": "node scripts/index/build-index.js",
    "index:vector": "node scripts/index/build-index.js --vector-only",
    "index:bm25": "node scripts/index/build-index.js --bm25-only",
    "index:test": "node scripts/index/build-index.js --test",
    "validate:phase2": "node scripts/validate-phase2.js",
    "test:retrieval": "node scripts/retrieval/test-retrieval.js",
    "validate:phase3": "node scripts/retrieval/validate-phase3.js",
    "test:context": "node scripts/context/test-context.js",
    "validate:phase3": "node scripts/retrieval/validate-phase3.js",
    "validate:phase4": "node scripts/context/validate-phase4.js",
    "test:reasoning": "node scripts/reasoning/test-reasoning.js",
    "validate:phase3": "node scripts/retrieval/validate-phase3.js",
    "validate:phase4": "node scripts/context/validate-phase4.js",
    "test:evaluation": "node scripts/evaluation/test-evaluation.js",
    "validate:phase6": "node scripts/evaluation/validate-phase6.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nishantwrp/gsoc-organizations"
  },
  "bugs": {
    "url": "https://github.com/nishantwrp/gsoc-organizations/issues"
  },
  "engines": {
    "node": "20.x"
  }
